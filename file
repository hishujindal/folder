//1RP Greeting Messages in English and French
import React from 'react'
function User(){
  return(
  <>
  < UserMessage name="Alice" language="en"/>
  < UserMessage name="Jean" language="fr"/>
  </>
)
}
function UserMessage(props){
  let message="";
  if(props.language==="en"){
    message= `Hello, ${props.name}`;
  }
  else if(props.language==="fr"){
    message=`Bonjour, ${props.name}`;
  }
  return <h3>{message}</h3>
}

function App(){
 return( 
 <div>
<User/>
 </div>

)
}

export default App
