//2 PROMISE Promise - Product Price Validator
function checkoutSystem(check){
    return new Promise(function(resolve,reject){
        setTimeout(function(){
            for(let i=0;i<check.length;i++){
                if(check[i].price<=0 || check[i].price==null){
                    reject("Reject")
                }
                
            }
            resolve("Resolve")
        },1500)
    })
}

