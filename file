//8SS Character Limit with Warning
import React, { useState } from 'react'
function App() {
    const[check,setcheck]=useState("");
    function change(e){
        if(20>=e.target.value.length){
            setcheck(e.target.value);
        }
    }
    function remain(e){
        let x=20-check.length;
        return x;
    }
    function limit(){
        if(check.length===20){
            return <h3 style={{color: "red"}}>Limit reached!</h3>
        }
    }
  return (
    <div>
        <h2>Check Character Limit</h2>
        <input type='text'
        onChange={change}
        value={check}
        placeholder='Type here'
        />
      <h3>Remaining: {remain()}</h3>
      <h3>{limit()}</h3>
    </div>
  )
}

export default App
