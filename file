//1SS Counter with limit 
import React, { useState } from 'react'
function App() {
  const[count,setcount]=useState(0);
  const increase=()=>{
    if(count<10){
      setcount(count+1);
    }
  }
  const decrease=()=>{
    if(count>0){
      setcount(count-1);
    }
  }
  return (
    <div>
      <h1>{count}</h1>
      <button onClick={increase}>+</button>
      <button onClick={decrease}>-</button>
    </div>
  )
}

export default App
