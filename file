//1CS Toggle Status Inside Object
import React, { useState } from 'react'
function App() {
    const [check,setcheck]=useState({
        title:"Learn React",
        completed: false
    });
    function tog(){
        setcheck({
            ...check,
            completed: !check.completed
        })
    }
  return (
    <div>
      <h2>{check.title} - {check.completed?"Completed":"Pending"}</h2>
      <button onClick={tog}>Toggle Status</button>
    </div>
  )
}

export default App
