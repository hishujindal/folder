import React, { useState } from 'react'
function App() {
    const [users, setUsers] = useState([
    { id: 1, name: "A" },
    { id: 2, name: "B" }
    ]);

    function user(){
        const update=users.map(function(u){
            if(u.id===2){
              return{ 
                ...u,
                name:"updated"
              }
            }
            return u;
        })
        setUsers(update);
    }
    function dispaly(){
        return users.map(function(u){
            return <h3>User List <br></br>
            User {u.id}: {u.name}
            </h3>
        })
    }
  return (
    <div>
        {dispaly()}
        <button onClick={user}>Update</button>
    </div>
  )
}

export default App
