//1 PROMISES Promise - Inventory Stock Checker
function stockAvailability(st){
    return new Promise(function(resolve,reject){
        setTimeout(function(){
            for(let i=0;i<st.length;i++){
                if(st[i].available==0){
                    reject("Rejected")
                    return;
                }
                else if(st[i].available<=st[i].requested){
                    resolve("Partial")
                    return;
                }
                else{
                    resolve("Available")
                    return;
                }
            }
        },1000)
    })
}
stockAvailability([
  {item: 'Shirts', requested: 10, available: 5 },
  {item: 'Jeans', requested: 6, available: 6 }
])

.then(function(resolve){
    console.log(resolve)
})
.catch(function(reject){
    console.log(reject);
})
